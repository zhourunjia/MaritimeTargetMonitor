<Window x:Class="Maritime.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Maritime.App"
        mc:Ignorable="d"
        Title="港区海域小目标识别及监控预警系统"
        Height="800"
        Width="1200"
        WindowState="Maximized"
        Background="#0E1420">
    <Grid Background="#0E1420">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <!-- 顶部Header（仅标题+Logo） -->
        <Border Grid.Row="0" Height="80" BorderBrush="#1E2A3A" BorderThickness="0,0,0,1">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#1D2A3A" Offset="0"/>
                    <GradientStop Color="#111826" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid ClipToBounds="False">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Grid.ColumnSpan="2"
                           Text="港区海域小目标识别及监控预警系统"
                           Foreground="#EAF2FF"
                           FontSize="22"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           Margin="0,0,280,0"/>
                <Border Grid.Column="1" CornerRadius="8" BorderBrush="#2A3B55" BorderThickness="1" Padding="6" Margin="0,0,18,0" VerticalAlignment="Center">
                    <Image Source="Assets/siat_logo.png"
                           Height="220"
                           Width="220"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                </Border>
            </Grid>
        </Border>

        <!-- 主内容区 -->
        <Grid Grid.Row="1" Background="#0E1420">
            <!-- 左侧菜单 -->
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧菜单 -->
            <Border Grid.Column="0" Background="{StaticResource MenuPanelBrush}" Padding="6" BorderBrush="{StaticResource MenuPanelBorderBrush}" BorderThickness="0,0,1,0">
                <StackPanel x:Name="LeftPanel">
                    <!-- 首页 -->
                    <Button x:Name="btnMainPage" Content="首页" Style="{StaticResource MenuButtonStyle}" Click="MenuButton_Click" Tag="MainPage"/>
                    
                    <!-- 算法 -->
                    <Expander x:Name="expAlgorithm" Header="算法" Margin="12,10,12,0" Style="{StaticResource MenuExpanderStyle}">
                        <StackPanel>
                            <Button x:Name="btnAlgSelect" Content="算法选择" Style="{StaticResource MenuSubButtonStyle}" Click="MenuButton_Click" Tag="AlgSelect"/>
                            <Button x:Name="btnAlgConfig" Content="算法参数配置" Style="{StaticResource MenuSubButtonStyle}" Click="MenuButton_Click" Tag="AlgConfig"/>
                        </StackPanel>
                    </Expander>
                    
                    <!-- 视频管理 -->
                    <Expander x:Name="expVideo" Header="视频管理" Margin="12,10,12,0" Style="{StaticResource MenuExpanderStyle}">
                        <StackPanel>
                            <Button x:Name="btnVisualVideo" Content="可视化视频" Style="{StaticResource MenuSubButtonStyle}" Click="MenuButton_Click" Tag="VisualVideo"/>
                            <Button x:Name="btnThermalVideo" Content="热成像视频" Style="{StaticResource MenuSubButtonStyle}" Click="MenuButton_Click" Tag="ThermalVideo"/>
                        </StackPanel>
                    </Expander>
                    
                    <!-- 无人机历史数据 -->
                    <Expander x:Name="expDroneHistory" Header="无人机历史数据" Margin="12,10,12,0" Style="{StaticResource MenuExpanderStyle}">
                        <StackPanel>
                            <Button x:Name="btnRobotHistory" Content="无人机历史" Style="{StaticResource MenuSubButtonStyle}" Click="MenuButton_Click" Tag="RobotHistory"/>
                        </StackPanel>
                    </Expander>
                    
                    <!-- 日志管理 -->
                    <Expander x:Name="expLog" Header="日志管理" Margin="12,10,12,0" Style="{StaticResource MenuExpanderStyle}">
                        <StackPanel>
                            <Button x:Name="btnAlarmLog" Content="报警日志" Style="{StaticResource MenuSubButtonStyle}" Click="MenuButton_Click" Tag="AlarmLog"/>
                            <Button x:Name="btnRobotRunLog" Content="无人机运行日志" Style="{StaticResource MenuSubButtonStyle}" Click="MenuButton_Click" Tag="RobotRunLog"/>
                            <Button x:Name="btnEnviromentLog" Content="环境日志" Style="{StaticResource MenuSubButtonStyle}" Click="MenuButton_Click" Tag="EnviromentLog"/>
                            <Button x:Name="btnVideoLog" Content="视频日志" Style="{StaticResource MenuSubButtonStyle}" Click="MenuButton_Click" Tag="VideoLog"/>
                        </StackPanel>
                    </Expander>
                    
                    <!-- 系统轨迹库 -->
                    <Button x:Name="btnSystemRoute" Content="系统轨迹库" Style="{StaticResource MenuButtonStyle}" Click="MenuButton_Click" Tag="SystemRoute"/>
                    
                    <!-- 系统手册 -->
                    <Button x:Name="btnSystemManual" Content="系统手册" Style="{StaticResource MenuButtonStyle}" Click="MenuButton_Click" Tag="SystemManual"/>
                    
                    <!-- 说明 -->
                    <Button x:Name="btnHelp" Content="说明" Style="{StaticResource MenuButtonStyle}" Click="MenuButton_Click" Tag="Help"/>
                </StackPanel>
            </Border>

            <!-- 中央内容区 -->
            <Border Grid.Column="1" Background="#0E1420" Margin="0,16,16,16" CornerRadius="8" BorderBrush="#1E2A3A" BorderThickness="1">
                <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden" Background="#0E1420"/>
            </Border>
        </Grid>
    </Grid>
</Window>
