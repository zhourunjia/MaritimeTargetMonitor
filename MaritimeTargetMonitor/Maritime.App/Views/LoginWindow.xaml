<Window x:Class="Maritime.App.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Maritime.App.Views"
        mc:Ignorable="d"
        Title="登录"
        Height="400"
        Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Background="#f0f0f0">
        <Border Background="#ffffff" Margin="50" CornerRadius="8">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="10" Opacity="0.2"/>
            </Border.Effect>
            <Grid Margin="30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="80"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- 标题 -->
                <StackPanel Grid.Row="0" VerticalAlignment="Center">
                    <TextBlock Text="海上小目标识别系统" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="用户登录" FontSize="14" Foreground="#666" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>
                
                <!-- 登录表单 -->
                <StackPanel Grid.Row="1" VerticalAlignment="Center">
                    <Grid Margin="0,20,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="用户名:" VerticalAlignment="Center" FontSize="14"/>
                        <TextBox x:Name="txtUsername" Grid.Column="1" Margin="10,0,0,0" Height="30" Padding="5"/>
                    </Grid>
                    
                    <Grid Margin="0,15,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="密码:" VerticalAlignment="Center" FontSize="14"/>
                        <PasswordBox x:Name="txtPassword" Grid.Column="1" Margin="10,0,0,0" Height="30" Padding="5"/>
                    </Grid>
                    
                    <Button x:Name="btnLogin" Content="登录" Margin="0,30,0,0" Height="35" Background="#3366cc" Foreground="White" FontSize="14" Click="btnLogin_Click"/>
                    
                    <TextBlock x:Name="lblError" Margin="0,15,0,0" Foreground="#cc3333" TextAlignment="Center" FontSize="12"/>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,20,0,0" HorizontalAlignment="Center">
                        <TextBlock Text="服务器连接:" FontSize="12" VerticalAlignment="Center"/>
                        <ToggleButton x:Name="toggleServer" Margin="10,0,0,0" Width="60" Height="20" IsChecked="True"/>
                        <TextBlock x:Name="lblServerStatus" Margin="10,0,0,0" FontSize="12" VerticalAlignment="Center" Text="在线模式"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
