<Page x:Class="Maritime.App.Pages.SystemManual"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:Maritime.App.Pages"
      mc:Ignorable="d"
      d:DesignHeight="600"
      d:DesignWidth="1000"
      Title="系统手册">

    <Grid Background="{StaticResource BackgroundBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24">
                <TextBlock Text="系统使用手册" FontSize="24" FontWeight="Bold" Margin="0,0,0,6"/>
                <TextBlock Text="更新时间：2026-02-05" FontSize="12" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,16"/>

                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="12" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="适用范围" FontWeight="Bold"/>
                        <TextBlock Text="本手册面向系统操作人员与维护人员，提供从无人机推流、算法处理到本地录像回放的完整说明。若某页面显示占位或暂无数据，通常表示该功能尚未接入实际设备或后台数据。" TextWrapping="Wrap" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <TextBlock Text="一、系统概览" FontSize="18" FontWeight="Bold" Margin="0,0,0,6"/>
                <TextBlock Text="系统用于接收无人机视频流，进行目标识别并将识别结果实时显示与本地录制。核心流程如下：" TextWrapping="Wrap"/>
                <TextBlock Text="1. 无人机（DJI Pilot 2）推送原始视频流到转发器（MediaMTX/rtsp-simple-server）。" TextWrapping="Wrap" Margin="0,6,0,0"/>
                <TextBlock Text="2. 算法从原始流读取视频，完成目标识别后推送处理后视频流。" TextWrapping="Wrap" Margin="0,2,0,0"/>
                <TextBlock Text="3. 主页拉取处理后画面，必要时同时录制到本地录像库。" TextWrapping="Wrap" Margin="0,2,0,0"/>

                <TextBlock Text="二、RC Pro 推流步骤（DJI Pilot 2 + 御3T）" FontSize="18" FontWeight="Bold" Margin="0,16,0,6"/>
                <TextBlock Text="1. 确保 RC Pro 与电脑处于同一局域网（通常为 Wi-Fi 同一网段）。" TextWrapping="Wrap"/>
                <TextBlock Text="2. 打开 DJI Pilot 2 → 直播推流设置 → 选择 RTMP 推流。" TextWrapping="Wrap" Margin="0,2,0,0"/>
                <TextBlock Text="3. 在主页“RC Pro 连接”模块点击“复制”推流地址，然后粘贴到 DJI Pilot 2 的 RTMP 地址中。" TextWrapping="Wrap" Margin="0,2,0,0"/>
                <TextBlock Text="4. 点击“检测”，状态显示为“推流检测成功”即表示端口可达。" TextWrapping="Wrap" Margin="0,2,0,0"/>
                <TextBlock Text="提示：若检测失败，请检查 RTMP 地址是否为本机正确的局域网 IP（如 192.168.x.x），而不是虚拟网卡地址。" TextWrapping="Wrap" Margin="0,2,0,0"/>

                <TextBlock Text="三、场景预设（推荐使用）" FontSize="18" FontWeight="Bold" Margin="0,16,0,6"/>
                <TextBlock Text="进入“算法参数配置”页，顶部选择场景并点击“应用预设”，系统会自动填写关键参数。" TextWrapping="Wrap"/>
                <TextBlock Text="1) 实时无人机：输入=DroneStreamUrl，输出=m3t，FPS=10，输出=1280x720，录制关闭。" TextWrapping="Wrap" Margin="0,6,0,0"/>
                <TextBlock Text="2) 本地演示：输入=DroneStreamUrl，输出=m3t，FPS=10，输出=1280x720，录制开启。" TextWrapping="Wrap" Margin="0,2,0,0"/>
                <TextBlock Text="3) 离线回放：禁用算法启动按钮，仅进入回放页查看本地录像。" TextWrapping="Wrap" Margin="0,2,0,0"/>

                <TextBlock Text="四、快速开始（首次使用）" FontSize="18" FontWeight="Bold" Margin="0,16,0,6"/>
                <TextBlock Text="按以下步骤可快速看到算法输出画面：" TextWrapping="Wrap"/>
                <TextBlock Text="1. 启动转发器服务（MediaMTX）。主页“可视化直播”模块会显示转发器状态。" TextWrapping="Wrap" Margin="0,6,0,0"/>
                <TextBlock Text="2. 按“RC Pro 推流步骤”完成推流配置，确保 RTMP 地址正确。" TextWrapping="Wrap" Margin="0,2,0,0"/>
                <TextBlock Text="3. 进入“算法参数配置”页选择“实时无人机”并点击“应用预设”。" TextWrapping="Wrap" Margin="0,2,0,0"/>
                <TextBlock Text="4. 回到主页点击“算法处理→启动”。状态显示“算法运行中”后即可看到画面。" TextWrapping="Wrap" Margin="0,2,0,0"/>
                <TextBlock Text="如需本地测试推流，可用下列命令推送测试视频：" TextWrapping="Wrap" Margin="0,6,0,0"/>
                <Border Background="#111827" CornerRadius="6" Padding="10" Margin="0,6,0,0">
                    <TextBlock Foreground="#E5E7EB" FontFamily="Consolas" TextWrapping="Wrap">
                        <Run Text="ffmpeg -re -stream_loop -1 -i C:\Users\15666\Desktop\MaritimeTargetMonitor\edgeyolo-main\edgeyolo-main\船只检测视频.mp4"/>
                        <LineBreak/>
                        <Run Text=" -vf scale=1280:720 -r 10 -c:v libx264 -preset veryfast -tune zerolatency -f flv rtmp://127.0.0.1:1935/live/raw"/>
                    </TextBlock>
                </Border>

                <TextBlock Text="五、主页功能说明" FontSize="18" FontWeight="Bold" Margin="0,16,0,6"/>
                <TextBlock Text="顶部状态栏：显示时间、热成像/可视化摄像头状态、服务器状态、PLC 状态、当前用户信息，以及导出诊断、修改密码、退出等操作。" TextWrapping="Wrap"/>
                <TextBlock Text="可视化直播模块：" FontWeight="Bold" Margin="0,8,0,0"/>
                <TextBlock Text="- 转发器路径：启动/停止转发器服务，RTMP/RTSP 地址会自动显示。" TextWrapping="Wrap" Margin="0,2,0,0"/>
                <TextBlock Text="- RC Pro 连接：复制推流地址、检测地址可达性、应用为算法输入源。" TextWrapping="Wrap" Margin="0,2,0,0"/>
                <TextBlock Text="算法处理模块：" FontWeight="Bold" Margin="0,8,0,0"/>
                <TextBlock Text="- 启动/停止：控制算法进程启动与停止。" TextWrapping="Wrap" Margin="0,2,0,0"/>
                <TextBlock Text="- 输入/输出：显示当前算法的流地址，便于核对配置。" TextWrapping="Wrap" Margin="0,2,0,0"/>
                <TextBlock Text="右侧无人机状态与控制：" FontWeight="Bold" Margin="0,8,0,0"/>
                <TextBlock Text="- 状态信息：显示无人机基础信息（后续接入数据源）。" TextWrapping="Wrap" Margin="0,2,0,0"/>
                <TextBlock Text="- 方向与速度控制：用于基本的巡检控制。" TextWrapping="Wrap" Margin="0,2,0,0"/>

                <TextBlock Text="六、算法参数配置页" FontSize="18" FontWeight="Bold" Margin="0,16,0,6"/>
                <TextBlock Text="顶部为场景预设，点击“应用预设”会自动填写关键参数；更多参数在“更多设置”中。" TextWrapping="Wrap"/>
                <TextBlock Text="- 重要路径：Python/脚本/权重/FFmpeg 路径需正确。" TextWrapping="Wrap" Margin="0,2,0,0"/>
                <TextBlock Text="- 输入源：原始视频流地址（如 rtmp://本机IP:1935/live/raw）。" TextWrapping="Wrap" Margin="0,2,0,0"/>
                <TextBlock Text="- 输出地址：算法输出流地址（如 rtmp://本机IP:1935/live/m3t）。" TextWrapping="Wrap" Margin="0,2,0,0"/>

                <TextBlock Text="七、本地录制与回放" FontSize="18" FontWeight="Bold" Margin="0,16,0,6"/>
                <TextBlock Text="1. 当 RecordEnabled=true 且算法运行时，系统自动录制算法输出流。" TextWrapping="Wrap"/>
                <TextBlock Text="2. 文件存储在 RecordDir 目录，按日期分文件夹保存：yyyy-MM-dd\HHmmss.mp4。" TextWrapping="Wrap" Margin="0,2,0,0"/>
                <TextBlock Text="3. 分段时长默认为 30 分钟。" TextWrapping="Wrap" Margin="0,2,0,0"/>
                <TextBlock Text="4. 系统会自动清理超过 30 天的历史录像文件夹。" TextWrapping="Wrap" Margin="0,2,0,0"/>
                <TextBlock Text="回放操作：进入“可视化视频”页，选择日期 → 点击“播放”，或点击“刷新库”同步录像列表。" TextWrapping="Wrap" Margin="0,4,0,0"/>

                <TextBlock Text="八、视频管理与日志" FontSize="18" FontWeight="Bold" Margin="0,16,0,6"/>
                <TextBlock Text="可视化视频：本地录像库浏览与播放。" TextWrapping="Wrap"/>
                <TextBlock Text="热成像视频：展示热成像信号状态和画面（需接入热成像源后生效）。" TextWrapping="Wrap" Margin="0,4,0,0"/>
                <TextBlock Text="报警日志 / 无人机运行日志 / 环境日志 / 视频日志：用于查看系统历史记录与事件。" TextWrapping="Wrap" Margin="0,4,0,0"/>

                <TextBlock Text="九、常见问题与排查" FontSize="18" FontWeight="Bold" Margin="0,16,0,6"/>
                <TextBlock Text="1. 主页无画面：" FontWeight="Bold" Margin="0,2,0,0"/>
                <TextBlock Text="- 确认 RC Pro 推流地址为本机正确局域网 IP。" TextWrapping="Wrap" Margin="0,2,0,0"/>
                <TextBlock Text="- 确认转发器已启动，RTMP/RTSP 端口可达。" TextWrapping="Wrap" Margin="0,2,0,0"/>
                <TextBlock Text="- 若使用算法输出流，需先启动算法。" TextWrapping="Wrap" Margin="0,2,0,0"/>
                <TextBlock Text="2. 算法启动失败：" FontWeight="Bold" Margin="0,6,0,0"/>
                <TextBlock Text="- 检查 Python/脚本/权重/FFmpeg 路径是否正确。" TextWrapping="Wrap" Margin="0,2,0,0"/>
                <TextBlock Text="3. 录像为空：" FontWeight="Bold" Margin="0,6,0,0"/>
                <TextBlock Text="- 确认 RecordEnabled=true 且算法运行中。" TextWrapping="Wrap" Margin="0,2,0,0"/>

                <TextBlock Text="十、性能与稳定性建议" FontSize="18" FontWeight="Bold" Margin="0,16,0,6"/>
                <TextBlock Text="- 推荐配置 GPU 或 TensorRT 以提升推理速度。" TextWrapping="Wrap"/>
                <TextBlock Text="- 适当降低输入帧率和分辨率，减少系统负载。" TextWrapping="Wrap" Margin="0,2,0,0"/>
                <TextBlock Text="- 长时间运行建议定期导出诊断信息并检查磁盘空间。" TextWrapping="Wrap" Margin="0,2,0,0"/>

                <Border Background="{StaticResource SurfaceAltBrush}" CornerRadius="8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="12" Margin="0,16,0,0">
                    <StackPanel>
                        <TextBlock Text="提示" FontWeight="Bold"/>
                        <TextBlock Text="如需升级或新增功能，请联系系统管理员或技术支持。" TextWrapping="Wrap" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
