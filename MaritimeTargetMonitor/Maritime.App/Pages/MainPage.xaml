<Page x:Class="Maritime.App.Pages.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:Maritime.App.Pages"
      xmlns:viewmodels="clr-namespace:Maritime.App.ViewModels"
      xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
      mc:Ignorable="d"
      d:DesignHeight="800"
      d:DesignWidth="1200"
      Title="MainPage">

    <Page.DataContext>
        <viewmodels:MainPageViewModel/>
    </Page.DataContext>

    <Page.Resources>
        <SolidColorBrush x:Key="TechPanelBrush" Color="#0A0F18"/>
        <SolidColorBrush x:Key="TechPanelBorderBrush" Color="#1D2A3A"/>
        <SolidColorBrush x:Key="TechCardBorderBrush" Color="#25364B"/>
        <SolidColorBrush x:Key="TechTextBrush" Color="#EAF2FF"/>
        <SolidColorBrush x:Key="TechMutedBrush" Color="#9DB4D5"/>
        <SolidColorBrush x:Key="TechAccentBrush" Color="#36C3FF"/>

        <LinearGradientBrush x:Key="TechCardGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#121C2B" Offset="0"/>
            <GradientStop Color="#0F1826" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="TechPrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#1B6FF2"/>
            <Setter Property="BorderBrush" Value="#57B7FF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2A84FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1557C0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TechGhostButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#0F1828"/>
            <Setter Property="BorderBrush" Value="#2A3B55"/>
            <Setter Property="Foreground" Value="{StaticResource TechTextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#152238"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#0B1220"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TechSecondaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#173157"/>
            <Setter Property="BorderBrush" Value="#2FD3FF"/>
            <Setter Property="Foreground" Value="#EAF6FF"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1D3E6D"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#132949"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TechTabItemStyle" TargetType="TabItem">
            <Setter Property="Foreground" Value="#CFE3FF"/>
            <Setter Property="Background" Value="#0E1828"/>
            <Setter Property="BorderBrush" Value="#22344D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter ContentSource="Header"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#18263B"/>
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#2F5A86"/>
                                <Setter Property="Foreground" Value="#EAF2FF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#142338"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TechTabControlStyle" TargetType="TabControl">
            <Setter Property="Background" Value="#0F1524"/>
            <Setter Property="BorderBrush" Value="#1E2A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0"
                                    Background="#0C1322"
                                    BorderBrush="#1E2A3A"
                                    BorderThickness="1,1,1,0"
                                    CornerRadius="8,8,0,0"
                                    Padding="6,4">
                                <TabPanel IsItemsHost="True" KeyboardNavigation.TabIndex="1"/>
                            </Border>
                            <Border Grid.Row="1"
                                    Background="#0F1524"
                                    BorderBrush="#1E2A3A"
                                    BorderThickness="1"
                                    CornerRadius="0,0,8,8">
                                <ContentPresenter ContentSource="SelectedContent" Margin="0" />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Background="#0E1420">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧：可视化直播 -->
            <Grid Grid.Column="0">
                <Border Background="#0B101A" Margin="10" CornerRadius="12" BorderBrush="#1E2A3A" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="12,10,12,8" LastChildFill="False">
                            <Border Background="#0F1B2A" BorderBrush="#2A3B55" BorderThickness="1" CornerRadius="10" Padding="10,4" DockPanel.Dock="Left">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="6" Height="6" Fill="#36C3FF" Margin="0,0,6,0"/>
                                    <TextBlock Text="可视化直播" Foreground="#E7EEF8" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#0B1524" BorderBrush="#24364C" BorderThickness="1" CornerRadius="10" Padding="10,4" DockPanel.Dock="Right">
                                <TextBlock x:Name="HomeLiveStatus" Text="等待拉流" Foreground="#36C3FF" FontSize="12" VerticalAlignment="Center"/>
                            </Border>
                        </DockPanel>

                        <Border Grid.Row="1" Margin="12" Background="#0E1420" CornerRadius="10" BorderBrush="#1E2A3A" BorderThickness="1">
                            <Grid Margin="8" Background="#0B0F16">
                                <vlc:VideoView x:Name="HomeLiveVideoView"/>
                                <Border VerticalAlignment="Top" Background="#1A2638" BorderBrush="#2A3B55" BorderThickness="1" CornerRadius="8" Padding="8" Margin="8">
                                    <TextBlock x:Name="HomeLiveOverlay" Foreground="#CFE3FF" FontSize="12"/>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- 右侧：快捷控制（深色科技风） -->
            <Border Grid.Column="1" Background="{StaticResource TechPanelBrush}" Margin="10" CornerRadius="12" BorderBrush="{StaticResource TechPanelBorderBrush}" BorderThickness="1" Padding="14">
                <StackPanel>
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="快捷控制" FontWeight="Bold" FontSize="15" Foreground="{StaticResource TechTextBrush}"/>
                        <Border Height="2" Margin="0,8,0,0" Background="{StaticResource TechAccentBrush}" Opacity="0.6" CornerRadius="1"/>
                    </StackPanel>

                    <Border Background="{StaticResource TechCardGradient}" BorderBrush="{StaticResource TechCardBorderBrush}" BorderThickness="1" Padding="14" CornerRadius="10" Margin="0,0,0,14">
                        <StackPanel>
                            <DockPanel LastChildFill="False" Margin="0,0,0,6">
                                <TextBlock Text="直通模式" Foreground="{StaticResource TechTextBrush}" FontSize="13" FontWeight="SemiBold"/>
                                <Border DockPanel.Dock="Right" Background="#142338" BorderBrush="#24415E" BorderThickness="1" CornerRadius="10" Padding="8,2">
                                    <TextBlock x:Name="DirectLiveStatus" Foreground="{StaticResource TechAccentBrush}" FontSize="12"/>
                                </Border>
                            </DockPanel>
                            <TextBlock Text="直接显示无人机原始流（不经算法）" Foreground="{StaticResource TechMutedBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,10"/>
                            <Button x:Name="DirectLiveButton" Content="进入直通模式" Style="{StaticResource TechSecondaryButton}" Click="DirectLiveButton_Click"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource TechCardGradient}" BorderBrush="{StaticResource TechCardBorderBrush}" BorderThickness="1" Padding="14" CornerRadius="10">
                        <StackPanel>
                            <TextBlock Text="一键启动" Foreground="{StaticResource TechTextBrush}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock Text="自动启动转发器→检测推流→启动算法→播放" Foreground="{StaticResource TechMutedBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,10"/>

                            <Button x:Name="OneKeyStartButton" Content="一键启动" Style="{StaticResource TechPrimaryButton}" Click="OneKeyStartButton_Click" Margin="0,0,0,10"/>

                            <UniformGrid Columns="2" Rows="2" Margin="0,2,0,0">
                                <Border Background="#0E1A2B" BorderBrush="#20334B" BorderThickness="1" CornerRadius="8" Padding="8" Margin="0,0,8,8">
                                    <StackPanel>
                                        <TextBlock Text="转发器" Foreground="{StaticResource TechMutedBrush}" FontSize="11"/>
                                        <TextBlock x:Name="OneKeyRelayStatus" Foreground="{StaticResource TechAccentBrush}" FontSize="12" Text="未启动"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#0E1A2B" BorderBrush="#20334B" BorderThickness="1" CornerRadius="8" Padding="8" Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock Text="推流" Foreground="{StaticResource TechMutedBrush}" FontSize="11"/>
                                        <TextBlock x:Name="OneKeyPushStatus" Foreground="{StaticResource TechAccentBrush}" FontSize="12" Text="未检测" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#0E1A2B" BorderBrush="#20334B" BorderThickness="1" CornerRadius="8" Padding="8" Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock Text="算法" Foreground="{StaticResource TechMutedBrush}" FontSize="11"/>
                                        <TextBlock x:Name="OneKeyAlgoStatus" Foreground="{StaticResource TechAccentBrush}" FontSize="12" Text="未启动"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#0E1A2B" BorderBrush="#20334B" BorderThickness="1" CornerRadius="8" Padding="8">
                                    <StackPanel>
                                        <TextBlock Text="播放" Foreground="{StaticResource TechMutedBrush}" FontSize="11"/>
                                        <TextBlock x:Name="OneKeyPlayStatus" Foreground="{StaticResource TechAccentBrush}" FontSize="12" Text="未播放" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="1" Background="#0E1420" Padding="10" BorderBrush="#1E2A3A" BorderThickness="1,0,0,0">
            <TabControl SelectedIndex="{Binding SelectedTabIndex}"
                        Foreground="#CFE3FF"
                        Style="{StaticResource TechTabControlStyle}"
                        ItemContainerStyle="{StaticResource TechTabItemStyle}">
                <TabItem Header="实时轨迹">
                    <Grid Background="#0F1524">
                        <TextBlock Text="实时轨迹区域" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#8AA0BF"/>
                    </Grid>
                </TabItem>
                <TabItem Header="查看图片">
                    <Grid Background="#0F1524">
                        <TextBlock Text="查看图片区域" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#8AA0BF"/>
                    </Grid>
                </TabItem>
            </TabControl>
        </Border>
    </Grid>
</Page>
