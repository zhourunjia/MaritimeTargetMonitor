<Page x:Class="Maritime.App.Pages.VisualVideo"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:Maritime.App.Pages"
      xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
      mc:Ignorable="d"
      d:DesignHeight="600"
      d:DesignWidth="1000"
      Title="可视化视频">

    <Page.Resources>
        <local:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <local:InverseBooleanConverter x:Key="InverseBooleanConverter"/>

        <Style TargetType="Button">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Width" Value="150"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Width" Value="160"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Margin" Value="20"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="AlternatingRowBackground" Value="#F5F5F5"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="HeadersVisibility" Value="All"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
        </Style>
    </Page.Resources>

    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="420"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <StackPanel Grid.Row="0" Margin="20,16,20,10">
            <TextBlock Text="可视化视频" FontSize="24" FontWeight="Bold" Margin="0,0,0,4"/>
            <TextBlock Text="本地录像库" FontSize="14" Foreground="{StaticResource TextMutedBrush}"/>
        </StackPanel>

        <!-- 过滤与操作栏 -->
        <Border Grid.Row="1" Margin="20,0,20,10" Background="{StaticResource SurfaceAltBrush}" CornerRadius="6" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="日期" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox Grid.Column="1" ItemsSource="{Binding DateOptions}" SelectedItem="{Binding SelectedDate}"/>
                <Button Grid.Column="2" Content="刷新库" Command="{Binding RefreshCommand}" Width="80"/>
                <TextBlock Grid.Column="3" Text="录像目录：" VerticalAlignment="Center" Margin="10,0,6,0"/>
                <TextBlock Grid.Column="4" Text="{Binding RecordDirDisplay}" VerticalAlignment="Center" Foreground="{StaticResource TextMutedBrush}" TextTrimming="CharacterEllipsis"/>
            </Grid>
        </Border>

        <!-- 本地视频播放 -->
        <Border Grid.Row="2" Margin="20" Background="#111" CornerRadius="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="本地录像播放" Foreground="White" FontSize="14" FontWeight="Bold" Margin="0,0,8,0"/>
                    <Button Content="选择文件" Click="SelectLocalVideoButton_Click" Margin="0,0,6,0"/>
                    <Button Content="停止" Click="StopLocalVideoButton_Click"/>
                    <TextBlock x:Name="LocalVideoStatus" Foreground="LightGreen" Margin="10,0,0,0"/>
                </StackPanel>
                <vlc:VideoView x:Name="LocalVideoView" Grid.Row="1"/>
            </Grid>
        </Border>

        <!-- 录像列表 -->
        <DataGrid Grid.Row="3" ItemsSource="{Binding VideoRecords}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="序号" Binding="{Binding Id}" Width="60"/>
                <DataGridTextColumn Header="文件名" Binding="{Binding VideoName}" Width="200"/>
                <DataGridTextColumn Header="日期" Binding="{Binding DateKey}" Width="110"/>
                <DataGridTextColumn Header="时间" Binding="{Binding AddTime}" Width="160"/>
                <DataGridTextColumn Header="大小" Binding="{Binding SizeText}" Width="90"/>
                <DataGridTemplateColumn Header="操作" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="播放" Command="{Binding DataContext.PlayCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
