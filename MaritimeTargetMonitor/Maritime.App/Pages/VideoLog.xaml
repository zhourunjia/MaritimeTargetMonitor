<Page x:Class="Maritime.App.Pages.VideoLog"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:Maritime.App.Pages"
      mc:Ignorable="d"
      d:DesignHeight="450"
      d:DesignWidth="800"
      Title="VideoLog">

    <Grid>
        <StackPanel Margin="20">
            <TextBlock Text="视频日志" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>
            <TextBlock Text="视频录制和事件日志页面" FontSize="16" Margin="0,0,0,10"/>
            <TextBlock Text="这里将显示视频录制和事件日志，包括录制时间、事件类型等信息。" FontSize="14" Foreground="#666"/>
        </StackPanel>
    </Grid>
</Page>
