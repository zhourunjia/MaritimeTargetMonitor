<Page x:Class="Maritime.App.Pages.AlgorithmConfig"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:Maritime.App.Pages"
      mc:Ignorable="d"
      d:DesignHeight="600"
      d:DesignWidth="1000"
      Title="AlgorithmConfig">

    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="20,16,20,8">
            <TextBlock Text="算法参数配置" FontSize="24" FontWeight="Bold" Margin="0,0,0,6"/>
            <TextBlock Text="配置算法、转发器与推流输入" FontSize="14" Foreground="#666"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="20,0,20,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧：算法控制 + 参数配置 -->
            <StackPanel Grid.Column="0">
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="12" Margin="0,0,0,12">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="算法处理" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Text=" | " Foreground="#666666" FontSize="12" VerticalAlignment="Center" Margin="6,0"/>
                            <TextBlock x:Name="AlgorithmStatusText" Text="算法未启动" Foreground="#666666" FontSize="12" VerticalAlignment="Center"/>
                            <Button x:Name="AlgorithmStartButton" Content="启动" Width="60" Margin="12,0,6,0" Click="AlgorithmStartButton_Click"/>
                            <Button x:Name="AlgorithmStopButton" Content="停止" Width="60" Click="AlgorithmStopButton_Click"/>
                            <Button x:Name="AlgorithmPrewarmButton" Content="预热" Width="60" Margin="6,0,0,0" Click="AlgorithmPrewarmButton_Click"/>
                            <Button x:Name="EnterPlaybackButton" Content="进入回放" Width="80" Margin="12,0,0,0" Visibility="Collapsed" Click="EnterPlaybackButton_Click"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <TextBlock Text="输入：" Foreground="#666666"/>
                            <TextBlock x:Name="AlgorithmInputText" Foreground="#0066cc" Margin="2,0,12,0"/>
                            <TextBlock Text="输出：" Foreground="#666666"/>
                            <TextBlock x:Name="AlgorithmOutputText" Foreground="#0066cc" Margin="2,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="12">
                    <local:AlgorithmConfigPanel x:Name="AlgorithmConfigPanel"/>
                </Border>
            </StackPanel>

            <!-- 右侧：转发器与推流 -->
            <Border Grid.Column="1" Background="{StaticResource SurfaceBrush}" CornerRadius="8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="12" Margin="12,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="转发器与推流" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

                        <Border Background="#151821" Padding="12" CornerRadius="8" Margin="0,0,0,12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="转发器" Foreground="White" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <TextBlock Text=" | " Foreground="#666666" FontSize="12" VerticalAlignment="Center" Margin="5,0"/>
                                    <TextBlock x:Name="HomeRelayStatus" Foreground="#00ff00" FontSize="12" VerticalAlignment="Center"/>
                                </StackPanel>

                                <TextBlock Grid.Row="1" Text="转发器路径" Foreground="#bbbbbb" Margin="0,8,0,4"/>
                                <TextBox Grid.Row="2" x:Name="HomeRelayPathBox" Height="46" TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Center"/>

                                <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,8,0,6">
                                    <Button Content="启动" Width="70" Click="HomeStartRelayButton_Click" Margin="0,0,8,0"/>
                                    <Button Content="停止" Width="70" Click="HomeStopRelayButton_Click"/>
                                </StackPanel>

                                <Grid Grid.Row="4">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                                        <TextBlock Text="RTMP：" Foreground="#bbbbbb"/>
                                        <TextBlock x:Name="HomeRtmpUrlText" Foreground="#00ccff" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,4,0,0">
                                        <TextBlock Text="RTSP：" Foreground="#bbbbbb"/>
                                        <TextBlock x:Name="HomeRtspUrlText" Foreground="#00ccff" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Background="#151821" Padding="12" CornerRadius="8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="RC Pro 连接" Foreground="White" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <TextBlock Text=" | " Foreground="#666666" FontSize="12" VerticalAlignment="Center" Margin="5,0"/>
                                    <TextBlock x:Name="RcProStatusText" Text="未连接" Foreground="#cccccc" FontSize="12" VerticalAlignment="Center"/>
                                </StackPanel>

                                <TextBlock Grid.Row="1"
                                           Text="步骤：1) DJI Pilot 2 开启直播推流  2) 填入 RTMP 地址  3) 点击检测"
                                           Foreground="#bbbbbb"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Margin="0,6,0,8"/>

                                <Grid Grid.Row="2" Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="推流地址" Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBox Grid.Column="1" x:Name="RcProAddressBox" Height="40" TextWrapping="Wrap" AcceptsReturn="True" IsReadOnly="True" VerticalContentAlignment="Center"/>
                                    <Button Grid.Column="2" Content="复制" Width="60" Margin="6,0,0,0" Click="RcProCopyButton_Click"/>
                                </Grid>

                                <Grid Grid.Row="3" Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="输入源" Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBox Grid.Column="1" x:Name="RcProInputBox" Height="40" TextWrapping="Wrap" AcceptsReturn="True" TextChanged="RcProInputBox_TextChanged" VerticalContentAlignment="Center"/>
                                </Grid>

                                <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,0,0,6">
                                    <Button Content="应用为算法输入源" Width="140" Margin="0,0,8,0" Click="RcProApplyButton_Click"/>
                                    <Button Content="检测" Width="70" Click="RcProDetectButton_Click"/>
                                </StackPanel>

                                <TextBlock Grid.Row="5" x:Name="RcProDetailText" Foreground="#888888" FontSize="12" TextWrapping="Wrap"/>

                                <Border Grid.Row="6" Background="#10131A" CornerRadius="6" Padding="8" Margin="0,10,0,0">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="转发器接收路径" Foreground="White" FontWeight="Bold" FontSize="12" VerticalAlignment="Center"/>
                                            <Button x:Name="MtxRefreshButton" Content="刷新" Width="60" Margin="8,0,0,0" Click="MtxRefreshButton_Click"/>
                                        </StackPanel>
                                        <TextBlock x:Name="MtxPathText" Foreground="#00ccff" FontSize="12" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                        <TextBlock x:Name="MtxPathDetailText" Foreground="#888888" FontSize="12" Margin="0,2,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Page>
