<Page x:Class="Maritime.App.Pages.RobotRunLog"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:Maritime.App.Pages"
      mc:Ignorable="d"
      d:DesignHeight="450"
      d:DesignWidth="800"
      Title="RobotRunLog">

    <Grid>
        <StackPanel Margin="20">
            <TextBlock Text="无人机运行日志" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>
            <TextBlock Text="无人机运行状态日志页面" FontSize="16" Margin="0,0,0,10"/>
            <TextBlock Text="这里将显示无人机的运行状态日志，包括电池信息、飞行参数等。" FontSize="14" Foreground="#666"/>
        </StackPanel>
    </Grid>
</Page>
